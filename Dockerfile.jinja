##################
# PYTHON BUILDER #
##################
FROM python:3.14-alpine AS backend-builder

WORKDIR /usr/src/app

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

ARG RUIZ_PUBLIC_PYPI_URL=https://git.ruiz.wang/api/packages/Public/pypi/simple/

RUN apk update && \
    apk add --no-cache \
        bash \
        build-base \
        cargo \
        gcc \
        git \
        libffi-dev \
        make \
        musl-dev \
        openssl-dev \
        postgresql-dev \
        python3-dev \
        zlib

RUN pip install --no-cache-dir --upgrade pip uv

COPY pyproject.toml uv.lock ./
RUN uv export --frozen --no-dev --no-editable --no-emit-project -o requirements.txt && \
    pip wheel \
        --no-cache-dir \
        --wheel-dir /usr/src/app/wheels \
        --requirement requirements.txt \
        --extra-index-url "${RUIZ_PUBLIC_PYPI_URL}"

{% if include_frontend %}
###################
# ANGULAR BUILDER #
###################
FROM node:24 AS frontend-builder

WORKDIR /usr/src/frontend-src

ARG VERSION=0.1.0

COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci

COPY frontend/ ./
RUN sed -i 's/"version":\s*".*"/"version": "'"${VERSION}"'"/' package.json
RUN npm run build
{% endif %}

#########
# FINAL #
#########
FROM python:3.14-alpine

RUN mkdir -p /home/app
RUN addgroup -S app && adduser -S app -G app

ENV HOME=/home/app
ENV APP_HOME=/home/app/web
RUN mkdir -p \
    $APP_HOME/backend \
    $APP_HOME/backend/staticfiles \
    $APP_HOME/backend/mediafiles \
    $APP_HOME/frontend \
    $APP_HOME/well-known
WORKDIR $APP_HOME/backend

RUN apk update && \
    apk add --no-cache \
        bash \
        curl \
        libgcc \
        libheif \
        libmagic \
        libpq \
        nano \
        nginx \
        postgresql-client \
        supervisor \
        vips

COPY --from=backend-builder /usr/src/app/wheels /wheels
COPY --from=backend-builder /usr/src/app/requirements.txt $APP_HOME/requirements.txt

RUN pip install --no-cache-dir /wheels/*

COPY docker-entrypoint.sh $APP_HOME/docker-entrypoint.sh
COPY supervisor.conf $APP_HOME/supervisor.conf
COPY nginx_conf/default.conf /etc/nginx/conf.d/default.conf
COPY nginx_conf/nginx.conf /etc/nginx/nginx.conf

COPY backend/ $APP_HOME/backend/
COPY well-known/ $APP_HOME/well-known/
{% if include_frontend %}
COPY --from=frontend-builder /usr/src/frontend-src/www/ $APP_HOME/frontend/
{% endif %}

RUN chmod +x $APP_HOME/docker-entrypoint.sh && \
    mkdir -p $APP_HOME/logs $APP_HOME/tmp && \
    chown -R app:app $APP_HOME

USER app

ARG VERSION=0.1.0
ENV VERSION=${VERSION}

ENTRYPOINT ["/home/app/web/docker-entrypoint.sh"]
CMD ["supervisord", "-c", "/home/app/web/supervisor.conf"]
