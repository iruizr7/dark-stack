[supervisord]
nodaemon = true

[program:nginx]
user = app
directory = /home/app/web
command = /usr/sbin/nginx -p /home/app/web -g "daemon off;"
stdout_logfile = /dev/stdout
stdout_logfile_maxbytes = 0
stderr_logfile = /dev/stderr
stderr_logfile_maxbytes = 0
autostart = true
autorestart = true

[program:web]
user = app
directory = /home/app/web/backend
{% if use_asgi -%}
command = /usr/local/bin/daphne -b 127.0.0.1 -p 8000 main.asgi:application
{% else -%}
command = /usr/local/bin/python manage.py runserver 127.0.0.1:8000
{% endif -%}
stdout_logfile = /dev/stdout
stdout_logfile_maxbytes = 0
stderr_logfile = /dev/stderr
stderr_logfile_maxbytes = 0
autostart = true
autorestart = true
