[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ project_name }}"
requires-python = ">=3.14"
dependencies = [
{% if use_asgi -%}
    "channels[daphne]>=4.3.2",
{% endif -%}
    "django>=6.0.3",
    "django-cleanup>=9.0.0",
    "django-cors-headers>=4.9.0",
    "django-silk>=5.5.0",
    "pillow>=12.1.1",
    "psycopg-pool>=3.3.0",
    "psycopg[binary]>=3.3.3",
    "python-magic>=0.4.27",
    "pyvips>=3.1.1",
    "sentry-sdk>=2.55.0",
]
