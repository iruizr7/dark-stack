[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ project_name }}"
requires-python = ">=3.14"
dependencies = [
{% if use_celery -%}
    "celery>=5.6.2",
    "channels-redis>=4.3.0",
{% endif -%}
{% if use_asgi -%}
    "channels[daphne]>=4.3.2",
{% endif -%}
    "dj-rest-auth>=7.2.0",
    "django>=6.0.3",
    "django-allauth>=65.15.0",
{% if use_celery -%}
    "django-celery-beat>=2.9.0",
    "django-celery-results>=2.6.0",
{% endif -%}
    "django-cleanup>=9.0.0",
    "django-cors-headers>=4.9.0",
    "django-silk>=5.5.0",
    "django-templated-email>=3.1.1",
    "djangorestframework>=3.17.0",
    "pillow>=12.1.1",
    "psycopg-pool>=3.3.0",
    "psycopg[binary]>=3.3.3",
    "python-magic>=0.4.27",
    "pyvips>=3.1.1",
    "requests>=2.32.5",
    "sentry-sdk>=2.55.0",
]
