#!/usr/bin/env bash

set -euo pipefail

if [[ ! -f uv.lock ]]; then
  echo "uv.lock is required to build the Docker image." >&2
  echo "Generate it locally with: uv lock" >&2
  exit 1
fi

if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  if ! git ls-files --error-unmatch uv.lock >/dev/null 2>&1; then
    echo "uv.lock exists but is not committed." >&2
    echo "Commit the tested lockfile before building the Docker image." >&2
    exit 1
  fi

  if [[ -n "$(git status --porcelain -- uv.lock)" ]]; then
    echo "uv.lock has local changes." >&2
    echo "Commit the tested lockfile before building the Docker image." >&2
    exit 1
  fi
fi

VERSION="$(cat VERSION)"
DOCKER_BUILDKIT=1 docker buildx build \
  --build-arg VERSION="$VERSION" \
  -t {{ project_slug }}:"$VERSION" \
  .
