worker_processes auto;
pid /home/app/web/tmp/nginx.pid;

events {
    worker_connections 1024;
}

http {
    client_body_temp_path /home/app/web/tmp/client_body_temp;
    fastcgi_temp_path /home/app/web/tmp/fastcgi_temp;
    proxy_temp_path /home/app/web/tmp/proxy_temp;
    scgi_temp_path /home/app/web/tmp/scgi_temp;
    uwsgi_temp_path /home/app/web/tmp/uwsgi_temp;

    sendfile on;
    tcp_nopush on;
    tcp_nodelay on;
    keepalive_timeout 65;
    types_hash_max_size 2048;

    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    ssl_protocols TLSv1 TLSv1.1 TLSv1.2;
    ssl_prefer_server_ciphers on;

    access_log /dev/stdout;
    error_log /dev/stderr;

    gzip on;
    gzip_disable "msie6";

    client_max_body_size 100M;

    include /etc/nginx/conf.d/*.conf;
}
