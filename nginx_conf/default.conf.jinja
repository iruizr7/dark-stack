upstream django_server {
    server 127.0.0.1:8000;
}

access_log /dev/stdout;
error_log /dev/stdout info;

server {
    listen 8080;

    location ~ ^/(api|__admin__|__debug2__|accounts) {
        proxy_pass http://django_server;
        proxy_http_version 1.1;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header X-Forwarded-For $http_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $upstream_forwarded_proto;
        proxy_set_header Host $http_host;
        proxy_redirect off;
    }

    location /static/ {
        expires 1h;
        add_header Cache-Control "public";
        alias /home/app/web/backend/staticfiles/;
    }

    location /media/ {
        expires 1h;
        add_header Cache-Control "public";
        alias /home/app/web/backend/mediafiles/;
    }

    location /.well-known/ {
        expires 1h;
        add_header Cache-Control "public";
        alias /home/app/web/well-known/;
    }

{% if include_frontend %}
    location / {
        root /home/app/web/frontend/;
        try_files $uri $uri/ /index.html;
    }
{% else %}
    location / {
        proxy_pass http://django_server;
        proxy_http_version 1.1;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header X-Forwarded-For $http_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $upstream_forwarded_proto;
        proxy_set_header Host $http_host;
        proxy_redirect off;
    }
{% endif %}
}
