SILKY_AUTHENTICATION = True
SILKY_AUTHORISATION = True


def silky_custom_perms(user):
    return user.is_superuser


def silky_intercept_filter(request):
    user_agent = request.META.get('HTTP_USER_AGENT', '').lower()
    is_ping = any(agent in user_agent for agent in ['datadog', 'uptime-kuma', 'uptimerobot'])
    return not is_ping


SILKY_INTERCEPT_FUNC = silky_intercept_filter
